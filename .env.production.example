# Core application
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=/api/v1

# Database
POSTGRES_USER=atlas
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=api_platform

# Security
JWT_SECRET=replace-with-a-long-random-secret

# Optional Stripe (disabled unless you really want it)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal API mode (optional)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.paypal.com

# PayPal manual collection mode
PAYPAL_DISPLAY_NAME=
PAYPAL_ACCOUNT_EMAIL=
PAYPAL_PAYMENT_LINK=
PAYPAL_RECIPIENT_NOTE=

# Alipay manual collection
ALIPAY_DISPLAY_NAME=
ALIPAY_ACCOUNT=
ALIPAY_PAYMENT_LINK=
ALIPAY_QR_CODE_URL=
ALIPAY_RECIPIENT_NOTE=

# WeChat manual collection
WECHAT_DISPLAY_NAME=
WECHAT_ACCOUNT=
WECHAT_PAYMENT_LINK=
WECHAT_QR_CODE_URL=
WECHAT_RECIPIENT_NOTE=

# USDT (recommended primary route for overseas users)
USDT_WALLET_ADDRESS=
USDT_NETWORK=TRC20
USDT_EVM_RPC_URL=
USDT_ERC20_CONTRACT=
USDT_TRC20_CONTRACT=
TRONGRID_API_KEY=

# Registration email verification (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# Temporary bypass code for emergency/manual registration only.
# Leave empty in normal production use once SMTP is configured.
REGISTRATION_BYPASS_CODE=

# Optional notes
# 1. Use the same domain for APP_URL and FRONTEND_URL if nginx serves both frontend and api.
# 2. Preferred production setup for this project:
#    Alipay/WeChat personal collection + USDT(TRC20 primary for overseas) + optional PayPal.
