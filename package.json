{
  "name": "vgo-code",
  "version": "1.0.0",
  "description": "VGO CODE desktop shell for the bundled agent CLI.",
  "main": "electron/main.js",
  "author": "VGO CODE",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack": "electron-builder --win dir",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.vgo.code",
    "productName": "VGO CODE",
    "files": [
      "electron/**/*",
      "server/**/*",
      "vendor/package/**/*",
      "ui/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-web",
        "to": "dist-web"
      }
    ],
    "asarUnpack": [
      "vendor/package/**/*"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "afterPack": "./scripts/afterPack.js"
  },
  "devDependencies": {
    "electron": "^36.3.0",
    "electron-builder": "^25.1.8",
    "icon-gen": "^5.0.0",
    "playwright": "^1.59.1",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5"
  }
}
