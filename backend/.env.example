# Application
NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=api_platform
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Public app URL
APP_URL=http://localhost:3000

# Payment (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Payment (PayPal)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# Payment (USDT)
USDT_WALLET_ADDRESS=
USDT_NETWORK=TRC20
USDT_EVM_RPC_URL=
USDT_ERC20_CONTRACT=
USDT_TRC20_CONTRACT=
TRONGRID_API_KEY=

# Channel defaults
DEFAULT_CHANNEL_BALANCE=10000
